# Unveil — Environment Configuration
# Copy this file to .env.local and fill in your API keys
# Next.js uses .env.local (not .env) for local environment variables

# OpenAI (REQUIRED) — powers the 5 AI agents
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Serper.dev (OPTIONAL but recommended) — enables Google web search for fact-checking
# Get 2500 free searches at https://serper.dev (no credit card needed)
# Without this, the system falls back to DuckDuckGo (less reliable results)
SERPER_API_KEY=your_serper_api_key_here

# Unveil API Key (OPTIONAL) — set to require X-API-Key header on /api/analyze
# Leave unset or as placeholder to allow open access (rate-limited only)
UNVEIL_API_KEY=

# Server
NODE_ENV=development
